{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent-workflow/final-receipt/v1",
  "type": "object",
  "required": ["schema", "session_id", "artifacts", "sealed_at"],
  "properties": {
    "schema": {"const": "agent-workflow/final-receipt/v1"},
    "session_id": {"type": "string"},
    "sealed_at": {"type": "string"},
    "artifacts": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["path", "size", "sha256"], "properties": {"path": {"type": "string"}, "size": {"type": "integer", "minimum": 0}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}, "additionalProperties": false}}
  },
  "additionalProperties": false
}
