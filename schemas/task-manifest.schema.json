{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent-workflow/task-manifest/v1",
  "type": "object",
  "required": ["phase", "name", "tasks"],
  "properties": {
    "phase": {"type": ["integer", "string"]},
    "name": {"type": "string"},
    "mandatory_order": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "tier", "session", "prompt"],
        "properties": {
          "id": {"type": "string"},
          "tier": {"type": "string"},
          "session": {"type": "string"},
          "prompt": {"type": "string"},
          "dependencies": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
