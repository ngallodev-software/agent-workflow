{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent-workflow/completion/v1",
  "type": "object",
  "required": ["schema", "session_id", "result", "base_revision", "head_revision", "changed_files", "criteria", "commands", "unresolved"],
  "properties": {
    "schema": {"const": "agent-workflow/completion/v1"},
    "session_id": {"type": "string"},
    "ticket_id": {"type": ["string", "null"]},
    "pack_id": {"type": ["string", "null"]},
    "result": {"enum": ["completed", "partial", "failed", "blocked"]},
    "base_revision": {"type": ["string", "null"]},
    "head_revision": {"type": ["string", "null"]},
    "changed_files": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "criteria": {"type": "array", "items": {"type": "object", "required": ["id", "result"], "properties": {"id": {"type": "string"}, "result": {"enum": ["pass", "fail", "not_verified"]}, "evidence": {"type": "array", "items": {"type": "string"}}}, "additionalProperties": false}},
    "commands": {"type": "array", "items": {"type": "object", "required": ["argv", "cwd", "exit_code", "receipt"], "properties": {"argv": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "cwd": {"type": "string"}, "exit_code": {"type": "integer"}, "receipt": {"type": "string"}}, "additionalProperties": false}},
    "unresolved": {"type": "array", "items": {"type": "string"}},
    "usage": {"type": ["object", "null"]}
  },
  "additionalProperties": false
}
