{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent-workflow/execution-metrics/v1",
  "type": "object",
  "required": [
    "schema",
    "session_id",
    "stages"
  ],
  "properties": {
    "schema": {
      "const": "agent-workflow/execution-metrics/v1"
    },
    "session_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/stage"
      }
    }
  },
  "$defs": {
    "nullableNumber": {
      "type": [
        "integer",
        "number",
        "null"
      ],
      "minimum": 0
    },
    "stage": {
      "type": "object",
      "required": [
        "stage",
        "input_tokens",
        "cached_input_tokens",
        "output_tokens",
        "provider_total_tokens",
        "cost",
        "currency",
        "elapsed_seconds",
        "first_output_latency_seconds",
        "retry_count",
        "errors",
        "steer_count",
        "steer_acknowledged_count",
        "steer_pending_count"
      ],
      "properties": {
        "stage": {
          "type": "string",
          "pattern": "^(orchestrator|verification|total|child:[A-Za-z0-9][A-Za-z0-9_.-]{0,127})$"
        },
        "input_tokens": {
          "$ref": "#/$defs/nullableNumber"
        },
        "cached_input_tokens": {
          "$ref": "#/$defs/nullableNumber"
        },
        "output_tokens": {
          "$ref": "#/$defs/nullableNumber"
        },
        "provider_total_tokens": {
          "$ref": "#/$defs/nullableNumber"
        },
        "cost": {
          "$ref": "#/$defs/nullableNumber"
        },
        "currency": {
          "type": [
            "string",
            "null"
          ]
        },
        "elapsed_seconds": {
          "$ref": "#/$defs/nullableNumber"
        },
        "first_output_latency_seconds": {
          "$ref": "#/$defs/nullableNumber"
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "category",
              "detail"
            ],
            "properties": {
              "category": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "detail": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "steer_count": {
          "type": "integer",
          "minimum": 0
        },
        "steer_acknowledged_count": {
          "type": "integer",
          "minimum": 0
        },
        "steer_pending_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
