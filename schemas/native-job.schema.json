{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent-workflow/native-job/v1",
  "type": "object",
  "required": [
    "schema",
    "job_id",
    "ticket_id",
    "prompt_path",
    "worktree_target",
    "path_policy",
    "acceptance_commands",
    "review_requirement"
  ],
  "properties": {
    "schema": {"const": "agent-workflow/native-job/v1"},
    "job_id": {"type": "string", "minLength": 1},
    "ticket_id": {"type": "string", "minLength": 1},
    "prompt_path": {"type": "string", "minLength": 1},
    "worktree_target": {"type": "string", "minLength": 1},
    "path_policy": {
      "type": "object",
      "required": ["allowed_paths"],
      "properties": {
        "allowed_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "forbidden_paths": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1},
          "default": []
        }
      },
      "additionalProperties": false
    },
    "acceptance_commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "argv"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "argv": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          },
          "cwd": {"type": "string", "default": "."},
          "timeout_seconds": {"type": "integer", "minimum": 1, "default": 300},
          "result_format": {"enum": ["exit-code", "junit"], "default": "exit-code"},
          "junit_path": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    },
    "review_requirement": {
      "type": "object",
      "required": ["required"],
      "properties": {
        "required": {"type": "boolean"},
        "independent": {"type": "boolean", "default": false}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
